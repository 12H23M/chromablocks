; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="ChromaBlocks"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6")
boot_splash/bg_color=Color(0.961, 0.941, 0.922, 1)
boot_splash/show_image=false
config/icon="res://icon.svg"

[autoload]

GameConstants="*res://scripts/core/game_constants.gd"
AppColors="*res://scripts/core/app_colors.gd"
SaveManager="*res://scripts/utils/save_manager.gd"
SoundManager="*res://scripts/utils/sound_manager.gd"
MusicManager="*res://scripts/utils/music_manager.gd"
AdManager="*res://scripts/utils/ad_manager.gd"
AnalyticsManager="*res://scripts/utils/analytics_manager.gd"

[display]

window/size/viewport_width=393
window/size/viewport_height=852
window/stretch/mode="canvas_items"
window/stretch/aspect="keep_width"
window/handheld/orientation=1

[input_devices]

pointing/emulate_touch_from_mouse=true

[rendering]

renderer/rendering_method="mobile"
textures/vram_compression/import_etc2_astc=true
